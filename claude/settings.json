{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Read(**)",
      "Write(src/**)",
      "Write(docs/**)",
      "Write(test/**)",
      "Write(tests/**)",
      "Write(__tests__/**)",
      "Write(.tmp/**)",
      "Write(*.md)",
      "Write(package.json)",
      "Write(tsconfig.json)",
      "Write(*.config.*)",
      "Write(.gitignore)",
      "Write(scripts/**)",
      "Write(go.mod)",
      "Write(Makefile)",
      "Write(Dockerfile)",
      "Write(**/*.tf)",
      "Write(**/*.yaml)",
      "Write(**/*.yml)",
      "Bash(git:*)",
      "Bash(npm:*)",
      "Bash(pnpm:*)",
      "Bash(yarn:*)",
      "Bash(bun:*)",
      "Bash(gh:*)",
      "Bash(go:*)",
      "Bash(make:*)",
      "Bash(docker:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(terraform:*)",
      "Bash(rm .tmp/**)",
      "Bash(ls:*)",
      "Bash(osascript -e:*)",
      "mcp__github__*",
      "mcp__chrome-devtools__*",
      "mcp__serena__*",
      "mcp__context7__*",
      "mcp__playwright__*",
      "WebFetch(domain:aws.amazon.com)",
      "WebFetch(domain:awscli.amazonaws.com)",
      "WebFetch(domain:docs.aws.amazon.com)",
      "WebFetch(domain:repost.aws)",
      "WebFetch(domain:docs.cloud.google.com)",
      "WebFetch(domain:support.google.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:registry.terraform.io)",
      "WebFetch(domain:registry.circleci.com)",
      "WebFetch(domain:circleci.com)",
      "WebFetch(domain:go.dev)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:www.hashicorp.com)",
      "WebFetch(domain:datatracker.ietf.org)",
      "WebFetch(domain:tools.ietf.org)",
      "WebFetch(domain:www.iana.org)",
      "WebFetch(domain:www.icann.org)",
      "WebFetch(domain:googlecloudplatform.github.io)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(terraform apply:*)",
      "Bash(terraform destroy:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(cat:*)",
      "Bash(rm -rf:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Read(.env*)",
      "Read(**/.env*)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)",
      "Read(**/.ssh/**)",
      "Read(**/.aws/**)",
      "Read(**/.kube/**)",
      "Read(**/secrets*)",
      "Read(**/credentials*)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/.pgpass)",
      "Read(**/.netrc)",
      "Write(.env*)",
      "Write(**/.env*)",
      "Write(**/.git/config)",
      "Write(**/package-lock.json)",
      "Write(**/pnpm-lock.yaml)",
      "Write(**/yarn.lock)",
      "Write(**/biome.json)",
      "Write(**/.eslintrc)",
      "Write(**/.eslintrc.*)",
      "Write(**/ruff.toml)",
      "Write(**/.ruff.toml)",
      "Write(**/.golangci.yml)",
      "Write(**/.golangci.yaml)",
      "Write(**/clippy.toml)",
      "Write(**/.tflint.hcl)",
      "Write(**/.oxlintrc*)"
    ],
    "defaultMode": "auto"
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "serena",
    "github",
    "chrome-devtools",
    "context7",
    "playwright"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/protect-main-branch.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r 'if (.tool_input.command // \"\" | test(\"gh pr create\")) then (.tool_response.stdout // \"\" | match(\"https://github\\\\.com/\\\\S+\") | .string) // empty else empty end' | { read -r url; [ -n \"$url\" ] && echo \"{\\\"systemMessage\\\": \\\"PR が作成されました: $url\\\"}\"; } 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); FILE=$(echo \"$INPUT\" | jq -r '.tool_input.file_path // empty' 2>/dev/null); if [ -n \"$FILE\" ] && [ -f \"$FILE\" ]; then case \"$FILE\" in *.ts|*.tsx|*.js|*.jsx|*.json|*.md) command -v prettier &>/dev/null && prettier --write \"$FILE\" 2>/dev/null ;; *.py) command -v black &>/dev/null && black -q \"$FILE\" 2>/dev/null ;; *.go) command -v gofmt &>/dev/null && gofmt -w \"$FILE\" 2>/dev/null ;; esac; fi"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/lint-feedback.sh",
            "statusMessage": "Linting..."
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -title \"Claude Code\" -message \"入力待ちプロンプトが表示されました\" -sound default"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/precompact-context.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/verify-tests.sh",
            "timeout": 100,
            "statusMessage": "Verifying tests..."
          },
          {
            "type": "command",
            "command": "terminal-notifier -title \"Claude Code\" -message \"作業が完了しました\" -sound Glass"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "terraform-code-generation@hashicorp": true,
    "terraform-module-generation@hashicorp": true,
    "terraform-provider-development@hashicorp": true,
    "frontend-design@claude-plugins-official": true,
    "context7@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "hashicorp": {
      "source": {
        "source": "github",
        "repo": "hashicorp/agent-skills"
      }
    }
  },
  "effortLevel": "high",
  "skipAutoPermissionPrompt": true,
  "toolSettings": {
    "bash": {
      "timeout": 300000
    }
  }
}
