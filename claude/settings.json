{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "BASH_DEFAULT_TIMEOUT_MS": "300000"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Read(**)",
      "Write(src/**)",
      "Write(docs/**)",
      "Write(test/**)",
      "Write(tests/**)",
      "Write(__tests__/**)",
      "Write(.tmp/**)",
      "Write(*.md)",
      "Write(package.json)",
      "Write(tsconfig.json)",
      "Write(*.config.*)",
      "Write(.gitignore)",
      "Write(scripts/**)",
      "Write(go.mod)",
      "Write(Makefile)",
      "Write(Dockerfile)",
      "Write(**/*.tf)",
      "Write(**/*.yaml)",
      "Write(**/*.yml)",
      "Bash(git:*)",
      "Bash(npm:*)",
      "Bash(pnpm:*)",
      "Bash(yarn:*)",
      "Bash(bun:*)",
      "Bash(gh:*)",
      "Bash(go:*)",
      "Bash(crit review:*)",
      "Bash(crit status:*)",
      "Bash(crit comment:*)",
      "Bash(make:*)",
      "Bash(docker:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(terraform:*)",
      "Bash(rm .tmp/**)",
      "Bash(ls:*)",
      "Bash(osascript -e:*)",
      "Bash(shellcheck:*)",
      "Bash(actionlint:*)",
      "Bash(tflint:*)",
      "Bash(uv run ruff check *)",
      "Bash(uv run pyright *)",
      "mcp__chrome-devtools__*",
      "mcp__serena__*",
      "mcp__context7__*",
      "mcp__playwright__*",
      "mcp__aws__*",
      "WebSearch",
      "WebFetch",
      "Skill(superpowers:requesting-code-review)",
      "Skill(superpowers:requesting-code-review:*)",
      "Read(~/.claude/plugins/cache/claude-plugins-official/superpowers/*/skills/requesting-code-review/**)",
      "Skill(session-start)",
      "Skill(session-start:*)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(terraform apply:*)",
      "Bash(terraform destroy:*)",
      "Bash(wget:*)",
      "Bash(cat:*)",
      "Bash(rm -rf:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Read(.env*)",
      "Read(**/.env*)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)",
      "Read(**/.ssh/**)",
      "Read(**/.aws/**)",
      "Read(**/.kube/**)",
      "Read(**/secrets*)",
      "Read(**/credentials*)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/.pgpass)",
      "Read(**/.netrc)",
      "Write(.env*)",
      "Write(**/.env*)",
      "Write(**/.git/config)",
      "Write(**/package-lock.json)",
      "Write(**/pnpm-lock.yaml)",
      "Write(**/yarn.lock)",
      "Write(**/biome.json)",
      "Write(**/.eslintrc)",
      "Write(**/.eslintrc.*)",
      "Write(**/ruff.toml)",
      "Write(**/.ruff.toml)",
      "Write(**/.golangci.yml)",
      "Write(**/.golangci.yaml)",
      "Write(**/clippy.toml)",
      "Write(**/.tflint.hcl)",
      "Write(**/.oxlintrc*)"
    ],
    "defaultMode": "auto"
  },
  "fallbackModel": [
    "claude-opus-4-6"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/protect-main-branch.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/guard-worktree-path.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/confirm-hard-gate.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify-pr-created.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/format-on-edit.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/lint-feedback.sh",
            "statusMessage": "Linting..."
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"入力待ちプロンプトが表示されました\" with title \"Claude Code\" sound name \"Ping\"'"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/precompact-context.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/Users/stkhr/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/verify-completion-claims.sh",
            "timeout": 30,
            "statusMessage": "Verifying completion claims..."
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/verify-tests.sh",
            "timeout": 100,
            "statusMessage": "Verifying tests..."
          },
          {
            "type": "command",
            "command": "osascript -e 'display notification \"作業が完了しました\" with title \"Claude Code\" sound name \"Glass\"'"
          },
          {
            "type": "command",
            "command": "if [ -x ~/.claude/hooks/session-sync.sh ]; then ~/.claude/hooks/session-sync.sh || true; fi"
          }
        ]
      }
    ]
  },
  "worktree": {
    "symlinkDirectories": [
      "node_modules",
      ".cache"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "terraform-code-generation@hashicorp": true,
    "terraform-module-generation@hashicorp": true,
    "terraform-provider-development@hashicorp": true,
    "frontend-design@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "crit@crit-marketplace": true
  },
  "extraKnownMarketplaces": {
    "hashicorp": {
      "source": {
        "source": "github",
        "repo": "hashicorp/agent-skills"
      }
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "crit-marketplace": {
      "source": {
        "source": "github",
        "repo": "kevindutra/crit"
      }
    }
  },
  "language": "japanese",
  "effortLevel": "xhigh",
  "advisorModel": "fable",
  "showClearContextOnPlanAccept": true,
  "autoUpdatesChannel": "stable",
  "tui": "fullscreen",
  "showThinkingSummaries": true,
  "theme": "dark",
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "model": "sonnet"
}
